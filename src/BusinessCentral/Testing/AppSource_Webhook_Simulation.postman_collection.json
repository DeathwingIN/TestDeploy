{
  "info": {
    "name": "AppSource Webhook Simulation",
    "description": "Simulates Microsoft AppSource webhooks sending events to the Azure Function Proxy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Simulate Subscribe",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{Mock_JWT_Token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"id\": \"11111111-2222-3333-4444-555555555555\",\r\n  \"activityId\": \"22222222-3333-4444-5555-666666666666\",\r\n  \"publisherId\": \"contoso\",\r\n  \"offerId\": \"google-address-validation\",\r\n  \"planId\": \"premium\",\r\n  \"quantity\": 10,\r\n  \"subscriptionId\": \"33333333-4444-5555-6666-777777777777\",\r\n  \"timeStamp\": \"2023-10-27T10:00:00Z\",\r\n  \"action\": \"Subscribe\",\r\n  \"status\": \"Success\"\r\n}"
        },
        "url": {
          "raw": "{{AzureFunctionUrl}}/api/AppSourceWebhookProxy",
          "host": [
            "{{AzureFunctionUrl}}"
          ],
          "path": [
            "api",
            "AppSourceWebhookProxy"
          ]
        }
      },
      "response": []
    },
